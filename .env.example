# Lanework Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# Database
# ============================================================================
DATABASE_URL=postgresql+asyncpg://lanework:lanework@localhost:5432/lanework

# ============================================================================
# Authentication
# ============================================================================
# API key for service-to-service authentication
API_KEY=your-secure-api-key-here

# JWT configuration (optional, for user authentication)
JWT_SECRET=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# ============================================================================
# Tenant Configuration
# ============================================================================
# Default tenant ID for single-tenant mode
# Set to None for multi-tenant mode
TENANT_ID=default

# ============================================================================
# Orchestrator Configuration
# ============================================================================
ORCHESTRATOR_API_HOST=0.0.0.0
ORCHESTRATOR_API_PORT=8000
ORCHESTRATOR_API_DEBUG=true

# ============================================================================
# API Gateway Configuration
# ============================================================================
API_GATEWAY_API_HOST=0.0.0.0
API_GATEWAY_API_PORT=8080
API_GATEWAY_API_DEBUG=true

# ============================================================================
# Agent Configuration
# ============================================================================
# Shipment Tracking Agent
SHIPMENT_TRACKING_API_HOST=0.0.0.0
SHIPMENT_TRACKING_API_PORT=8001
SHIPMENT_TRACKING_API_DEBUG=true
SHIPMENT_TRACKING_TRUST_LEVEL=propose_only
SHIPMENT_TRACKING_ETA_DRIFT_THRESHOLD_MINUTES=30
SHIPMENT_TRACKING_WEBHOOK_SECRET=your-webhook-secret

# Inventory Agent
INVENTORY_API_HOST=0.0.0.0
INVENTORY_API_PORT=8002
INVENTORY_API_DEBUG=true
INVENTORY_TRUST_LEVEL=propose_only

# Route Optimization Agent
ROUTE_OPTIMIZATION_API_HOST=0.0.0.0
ROUTE_OPTIMIZATION_API_PORT=8003
ROUTE_OPTIMIZATION_API_DEBUG=true
ROUTE_OPTIMIZATION_TRUST_LEVEL=propose_only

# ============================================================================
# Voice Gateway Configuration
# ============================================================================
VOICE_GATEWAY_API_HOST=0.0.0.0
VOICE_GATEWAY_API_PORT=8009
VOICE_GATEWAY_API_DEBUG=true

# LiveKit configuration
LIVEKIT_HOST=localhost
LIVEKIT_PORT=7880
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret
LIVEKIT_ROOM_NAME=lanework-voice

# SIP trunk configuration
SIP_ENABLED=true
SIP_TRUNK_PROVIDER=twilio
SIP_PHONE_NUMBER=+1234567890

# STT/TTS configuration
STT_ENGINE=whisper
STT_LANGUAGE=en
TTS_ENGINE=coqui
TTS_VOICE=en_US/blizzard-lessac-medium

# Call recording
CALL_RECORDING_ENABLED=true
CALL_RECORDING_STORAGE=s3
CALL_RECORDING_BUCKET=lanework-call-recordings
CALL_CONSENT_REQUIRED=true

# ============================================================================
# Tool Bus Configuration
# ============================================================================
TOOL_BUS_URL=http://localhost:8000

# ============================================================================
# Observability
# ============================================================================
OTEL_ENABLED=true
OTEL_ENDPOINT=http://localhost:4317

# ============================================================================
# Rate Limiting
# ============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_BURST_SIZE=20

# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL=info
LOG_FORMAT=json

# ============================================================================
# External Services (for production)
# ============================================================================
# Carrier APIs
FEDEX_API_KEY=your-fedex-api-key
FEDEX_API_SECRET=your-fedex-api-secret
UPS_API_KEY=your-ups-api-key
USPS_API_KEY=your-usps-api-key

# Maps API
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
MAPBOX_ACCESS_TOKEN=your-mapbox-access-token

# Notification services
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

SENDGRID_API_KEY=your-sendgrid-api-key

# ============================================================================
# Database (for production)
# ============================================================================
# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=lanework
POSTGRES_PASSWORD=lanework
POSTGRES_DB=lanework

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
