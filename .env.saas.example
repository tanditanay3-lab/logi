# Lanework SaaS Layer Environment Variables

# ============================================================================
# Environment
# ============================================================================
ENVIRONMENT=development
DEBUG=true

# ============================================================================
# Database
# ============================================================================
# Neon Postgres connection string
SAAS_DATABASE_URL=postgresql+asyncpg://neondb_owner:npg_3YDpWTUa2ifV@ep-bitter-block-az9ls0rp.c-3.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# ============================================================================
# Authentication
# ============================================================================
# JWT Configuration
JWT_SECRET_KEY=change-me-in-production-use-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440  # 24 hours

# Neon Auth (optional - for future integration)
NEON_AUTH_URL=https://auth.neon.tech
NEON_AUTH_PROJECT_ID=your-neon-project-id
NEON_AUTH_API_KEY=your-neon-auth-api-key

# ============================================================================
# CORS
# ============================================================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:3001

# ============================================================================
# Agent Platform
# ============================================================================
# URL of the agent platform API Gateway
AGENT_PLATFORM_URL=http://localhost:8001
# API key for authenticating with agent platform
AGENT_PLATFORM_API_KEY=your-agent-platform-api-key

# ============================================================================
# Server
# ============================================================================
HOST=0.0.0.0
PORT=8000

